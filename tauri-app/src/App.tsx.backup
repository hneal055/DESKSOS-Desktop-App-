import { useState, useEffect } from "react";
import { invoke } from "@tauri-apps/api/core";
import "./styles.css";

// ==================== MODULE 1: QUICK DIAGNOSTICS DASHBOARD ====================
function DashboardModule() {
  const [systemInfo, setSystemInfo] = useState<any>(null);
  const [networkHealth, setNetworkHealth] = useState<any>(null);
  const [loading, setLoading] = useState(true);

  useEffect(() => {
    loadDashboard();
  }, []);

  const loadDashboard = async () => {
    try {
      const [sysInfo, netHealth] = await Promise.all([
        invoke("get_system_info"),
        invoke("check_network_health"),
      ]);
      setSystemInfo(sysInfo);
      setNetworkHealth(netHealth);
    } catch (err) {
      console.error("Dashboard load failed:", err);
    } finally {
      setLoading(false);
    }
  };

  if (loading) return <div className="text-center p-8 text-gray-400">Loading diagnostics...</div>;

  return (
    <div className="space-y-6">
      <div className="bg-gray-800 rounded-lg p-6">
        <h2 className="text-2xl font-bold text-blue-400 mb-4">System Health</h2>
        <div className="grid grid-cols-2 gap-4">
          <InfoCard label="Computer Name" value={systemInfo?.computer_name} />
          <InfoCard label="IP Address" value={systemInfo?.ip_address} />
          <InfoCard label="OS Version" value={systemInfo?.os_version} />
          <InfoCard label="Uptime" value={systemInfo?.uptime} />
          <InfoCard label="Disk Space" value={systemInfo?.disk_space_gb} />
          <InfoCard label="Memory" value={systemInfo?.memory_gb} />
          <InfoCard label="Domain" value={systemInfo?.domain} />
          <InfoCard label="Logged In User" value={systemInfo?.logged_in_user} />
        </div>
      </div>

      <div className="bg-gray-800 rounded-lg p-6">
        <h2 className="text-2xl font-bold text-green-400 mb-4">Network Health</h2>
        <div className="space-y-2">
          <StatusIndicator label="Gateway Ping" status={networkHealth?.gateway_ping} />
          <StatusIndicator label="DNS (1.1.1.1)" status={networkHealth?.dns_ping} />
          <StatusIndicator label="Internet (8.8.8.8)" status={networkHealth?.internet_ping} />
          <div className="flex items-center justify-between">
            <span className="text-gray-300">VPN Status:</span>
            <span className={`font-semibold ${networkHealth?.vpn_status === "Disconnected" ? "text-red-400" : "text-green-400"}`}>
              {networkHealth?.vpn_status}
            </span>
          </div>
        </div>
      </div>
    </div>
  );
}

// ==================== MODULE 2: FIX IT CENTER ====================
function FixItModule() {
  const [result, setResult] = useState<string>("");
  const [loading, setLoading] = useState(false);

  const runAction = async (action: string, command: () => Promise<any>) => {
    setLoading(true);
    setResult("");
    try {
      const res = await command();
      setResult(`✓ ${action}: ${JSON.stringify(res)}`);
    } catch (err) {
      setResult(`✗ ${action} failed: ${err}`);
    } finally {
      setLoading(false);
    }
  };

  return (
    <div className="space-y-6">
      {/* Network Fixes */}
      <div className="bg-gray-800 rounded-lg p-6">
        <h2 className="text-2xl font-bold text-purple-400 mb-4">🌐 Network & Connectivity</h2>
        <div className="grid grid-cols-2 gap-3">
          <ActionButton
            label="Flush DNS"
            onClick={() => runAction("Flush DNS", () => invoke("flush_dns"))}
            loading={loading}
          />
          <ActionButton
            label="Renew IP Address"
            onClick={() => runAction("Renew IP", () => invoke("renew_ip"))}
            loading={loading}
          />
          <ActionButton
            label="Reset Network Stack"
            onClick={() => runAction("Reset Network", () => invoke("reset_network"))}
            loading={loading}
            danger
          />
        </div>
      </div>

      {/* Printer Fixes */}
      <div className="bg-gray-800 rounded-lg p-6">
        <h2 className="text-2xl font-bold text-orange-400 mb-4">🖨️ Printer Rescue</h2>
        <div className="grid grid-cols-2 gap-3">
          <ActionButton
            label="Restart Print Spooler"
            onClick={() => runAction("Restart Spooler", () => invoke("restart_print_spooler"))}
            loading={loading}
          />
          <ActionButton
            label="Clear Print Queue"
            onClick={() => runAction("Clear Queue", () => invoke("clear_print_queue"))}
            loading={loading}
          />
        </div>
      </div>

      {/* Performance Fixes */}
      <div className="bg-gray-800 rounded-lg p-6">
        <h2 className="text-2xl font-bold text-yellow-400 mb-4">⚡ Performance Booster</h2>
        <div className="grid grid-cols-2 gap-3">
          <ActionButton
            label="Clear Temp Files"
            onClick={() => runAction("Clear Temp", () => invoke("clear_temp_files"))}
            loading={loading}
          />
        </div>
      </div>

      {/* Result Display */}
      {result && (
        <div className={`bg-gray-800 rounded-lg p-4 ${result.startsWith("✓") ? "border-l-4 border-green-500" : "border-l-4 border-red-500"}`}>
          <pre className="text-sm text-gray-300 whitespace-pre-wrap">{result}</pre>
        </div>
      )}
    </div>
  );
}

// ==================== MODULE 3: PROCESS MANAGER ====================
function ProcessModule() {
  const [processes, setProcesses] = useState<any[]>([]);
  const [loading, setLoading] = useState(false);

  const loadProcesses = async () => {
    setLoading(true);
    try {
      const procs = await invoke("get_top_processes", { limit: 10 });
      setProcesses(procs as any[]);
    } catch (err) {
      console.error("Failed to load processes:", err);
    } finally {
      setLoading(false);
    }
  };

  const killProc = async (pid: number) => {
    if (confirm(`Kill process ${pid}?`)) {
      try {
        await invoke("kill_process", { pid });
        alert("Process terminated");
        loadProcesses();
      } catch (err) {
        alert(`Failed to kill process: ${err}`);
      }
    }
  };

  useEffect(() => {
    loadProcesses();
  }, []);

  return (
    <div className="space-y-6">
      <div className="bg-gray-800 rounded-lg p-6">
        <div className="flex justify-between items-center mb-4">
          <h2 className="text-2xl font-bold text-red-400">Resource Hog Hunter</h2>
          <button
            onClick={loadProcesses}
            className="px-4 py-2 bg-blue-600 hover:bg-blue-700 rounded text-white"
            disabled={loading}
          >
            {loading ? "Loading..." : "Refresh"}
          </button>
        </div>
        <div className="space-y-2">
          {processes.map((proc) => (
            <div key={proc.pid} className="flex items-center justify-between bg-gray-700 p-3 rounded">
              <div className="flex-1">
                <div className="font-semibold text-white">{proc.name}</div>
                <div className="text-sm text-gray-400">PID: {proc.pid}</div>
              </div>
              <div className="text-right mr-4">
                <div className="text-yellow-400">{proc.cpu_percent?.toFixed(1)}% CPU</div>
                <div className="text-blue-400">{proc.memory_mb?.toFixed(0)} MB</div>
              </div>
              <button
                onClick={() => killProc(proc.pid)}
                className="px-3 py-1 bg-red-600 hover:bg-red-700 rounded text-white text-sm"
              >
                Kill
              </button>
            </div>
          ))}
        </div>
      </div>
    </div>
  );
}


// ==================== MODULE 5: ACTIVE DIRECTORY ====================
function ActiveDirectoryModule() {
  const [username, setUsername] = useState("");
  const [userInfo, setUserInfo] = useState<any>(null);
  const [groups, setGroups] = useState<string[]>([]);
  const [newPassword, setNewPassword] = useState("");
  const [mustChangePassword, setMustChangePassword] = useState(true);
  const [result, setResult] = useState("");
  const [loading, setLoading] = useState(false);
  const [searchLoading, setSearchLoading] = useState(false);

  const searchUser = async () => {
    if (!username.trim()) return;
    setSearchLoading(true);
    setResult("");
    try {
      const [info, groupList] = await Promise.all([
        invoke("search_ad_user", { username }),
        invoke("get_ad_user_groups", { username }),
      ]);
      setUserInfo(info);
      setGroups(groupList as string[]);
      setResult(`✓ Found user: ${(info as any).name}`);
    } catch (err) {
      setResult(`✗ Search failed: ${err}`);
      setUserInfo(null);
      setGroups([]);
    } finally {
      setSearchLoading(false);
    }
  };

  const unlockAccount = async () => {
    if (!username.trim()) return;
    setLoading(true);
    try {
      const res = await invoke("unlock_ad_user", { username });
      setResult(`✓ ${res}`);
      await searchUser(); // Refresh user info
    } catch (err) {
      setResult(`✗ Unlock failed: ${err}`);
    } finally {
      setLoading(false);
    }
  };

  const resetPassword = async () => {
    if (!username.trim() || !newPassword.trim()) {
      setResult("✗ Username and password required");
      return;
    }
    setLoading(true);
    try {
      const res = await invoke("reset_ad_password", {
        username,
        newPassword,
        mustChange: mustChangePassword,
      });
      setResult(`✓ ${res}`);
      setNewPassword("");
    } catch (err) {
      setResult(`✗ Password reset failed: ${err}`);
    } finally {
      setLoading(false);
    }
  };

  const generatePassword = async () => {
    try {
      const pass = await invoke("generate_secure_password", { length: 12 });
      setNewPassword(pass as string);
      setResult("✓ Secure password generated");
    } catch (err) {
      setResult(`✗ Password generation failed: ${err}`);
    }
  };

  const enableAccount = async () => {
    if (!username.trim()) return;
    setLoading(true);
    try {
      const res = await invoke("enable_ad_user", { username });
      setResult(`✓ ${res}`);
      await searchUser();
    } catch (err) {
      setResult(`✗ Enable failed: ${err}`);
    } finally {
      setLoading(false);
    }
  };

  const disableAccount = async () => {
    if (!username.trim()) return;
    if (!confirm(`Disable account ${username}?`)) return;
    setLoading(true);
    try {
      const res = await invoke("disable_ad_user", { username });
      setResult(`✓ ${res}`);
      await searchUser();
    } catch (err) {
      setResult(`✗ Disable failed: ${err}`);
    } finally {
      setLoading(false);
    }
  };

  const expirePassword = async () => {
    if (!username.trim()) return;
    setLoading(true);
    try {
      const res = await invoke("expire_ad_password", { username });
      setResult(`✓ ${res}`);
      await searchUser();
    } catch (err) {
      setResult(`✗ Expire password failed: ${err}`);
    } finally {
      setLoading(false);
    }
  };

  return (
    <div className="space-y-6">
      {/* User Search */}
      <div className="bg-gray-800 rounded-lg p-6">
        <h2 className="text-2xl font-bold text-purple-400 mb-4">🔍 User Lookup</h2>
        <div className="flex gap-3">
          <input
            type="text"
            value={username}
            onChange={(e) => setUsername(e.target.value)}
            onKeyPress={(e) => e.key === "Enter" && searchUser()}
            placeholder="Enter username (e.g., jdoe)"
            className="flex-1 px-4 py-2 bg-gray-900 text-white rounded border border-gray-700 focus:border-blue-500 focus:outline-none"
          />
          <button
            onClick={searchUser}
            disabled={searchLoading}
            className="px-6 py-2 bg-blue-600 hover:bg-blue-700 rounded text-white font-semibold disabled:opacity-50"
          >
            {searchLoading ? "Searching..." : "Search"}
          </button>
        </div>
      </div>

      {/* User Information */}
      {userInfo && (
        <div className="bg-gray-800 rounded-lg p-6">
          <h2 className="text-2xl font-bold text-green-400 mb-4">📋 User Information</h2>
          <div className="grid grid-cols-2 gap-4">
            <InfoCard label="Name" value={userInfo.name} />
            <InfoCard label="Username" value={userInfo.sam_account_name} />
            <InfoCard label="Email" value={userInfo.email || "N/A"} />
            <InfoCard label="Department" value={userInfo.department || "N/A"} />
            <InfoCard label="Title" value={userInfo.title || "N/A"} />
            <InfoCard label="Manager" value={userInfo.manager} />
            <InfoCard label="Last Logon" value={userInfo.last_logon_date} />
            <InfoCard label="Password Last Set" value={userInfo.password_last_set} />
          </div>

          <div className="mt-4 grid grid-cols-3 gap-4">
            <StatusCard
              label="Account Status"
              value={userInfo.enabled ? "Enabled" : "Disabled"}
              isGood={userInfo.enabled}
            />
            <StatusCard
              label="Locked Out"
              value={userInfo.locked_out ? "Yes" : "No"}
              isGood={!userInfo.locked_out}
            />
            <StatusCard
              label="Password Expired"
              value={userInfo.password_expired ? "Yes" : "No"}
              isGood={!userInfo.password_expired}
            />
          </div>

          {/* Group Memberships */}
          {groups.length > 0 && (
            <div className="mt-4">
              <h3 className="text-lg font-semibold text-gray-300 mb-2">Group Memberships ({groups.length})</h3>
              <div className="bg-gray-900 rounded p-3 max-h-40 overflow-y-auto">
                {groups.map((group, idx) => (
                  <div key={idx} className="text-sm text-gray-400 py-1">
                    • {group}
                  </div>
                ))}
              </div>
            </div>
          )}
        </div>
      )}

      {/* Account Management Actions */}
      {userInfo && (
        <div className="bg-gray-800 rounded-lg p-6">
          <h2 className="text-2xl font-bold text-orange-400 mb-4">🔧 Account Management</h2>
          <div className="grid grid-cols-2 gap-3">
            <ActionButton
              label="🔓 Unlock Account"
              onClick={unlockAccount}
              loading={loading}
              disabled={!userInfo.locked_out}
            />
            <ActionButton
              label={userInfo.enabled ? "❌ Disable Account" : "✅ Enable Account"}
              onClick={userInfo.enabled ? disableAccount : enableAccount}
              loading={loading}
              danger={userInfo.enabled}
            />
            <ActionButton
              label="⏰ Expire Password"
              onClick={expirePassword}
              loading={loading}
            />
          </div>
        </div>
      )}

      {/* Password Reset */}
      <div className="bg-gray-800 rounded-lg p-6">
        <h2 className="text-2xl font-bold text-yellow-400 mb-4">🔑 Password Reset</h2>
        <div className="space-y-4">
          <div>
            <label className="block text-sm text-gray-400 mb-2">New Password</label>
            <div className="flex gap-3">
              <input
                type="text"
                value={newPassword}
                onChange={(e) => setNewPassword(e.target.value)}
                placeholder="Enter new password or generate"
                className="flex-1 px-4 py-2 bg-gray-900 text-white rounded border border-gray-700 focus:border-blue-500 focus:outline-none font-mono"
              />
              <button
                onClick={generatePassword}
                className="px-4 py-2 bg-purple-600 hover:bg-purple-700 rounded text-white font-semibold"
              >
                🎲 Generate
              </button>
            </div>
          </div>

          <div className="flex items-center gap-2">
            <input
              type="checkbox"
              id="mustChange"
              checked={mustChangePassword}
              onChange={(e) => setMustChangePassword(e.target.checked)}
              className="w-4 h-4"
            />
            <label htmlFor="mustChange" className="text-gray-300">
              User must change password at next logon
            </label>
          </div>

          <button
            onClick={resetPassword}
            disabled={loading || !username.trim() || !newPassword.trim()}
            className="w-full px-6 py-3 bg-green-600 hover:bg-green-700 rounded text-white font-semibold disabled:opacity-50 disabled:cursor-not-allowed"
          >
            {loading ? "Resetting..." : "🔄 Reset Password"}
          </button>
        </div>
      </div>

      {/* Result Display */}
      {result && (
        <div
          className={`bg-gray-800 rounded-lg p-4 ${
            result.startsWith("✓") ? "border-l-4 border-green-500" : "border-l-4 border-red-500"
          }`}
        >
          <pre className="text-sm text-gray-300 whitespace-pre-wrap">{result}</pre>
        </div>
      )}
    </div>
  );
}

// ==================== MODULE 4: CUSTOM POWERSHELL ====================
function PowerShellModule() {
  const [command, setCommand] = useState("");
  const [output, setOutput] = useState("");
  const [loading, setLoading] = useState(false);

  const runCommand = async () => {
    if (!command.trim()) return;
    setLoading(true);
    try {
      const result = await invoke("run_custom_powershell", { command });
      setOutput(result as string);
    } catch (err) {
      setOutput(`Error: ${err}`);
    } finally {
      setLoading(false);
    }
  };

  return (
    <div className="space-y-4">
      <div className="bg-gray-800 rounded-lg p-6">
        <h2 className="text-2xl font-bold text-cyan-400 mb-4">PowerShell Console</h2>
        <textarea
          value={command}
          onChange={(e) => setCommand(e.target.value)}
          className="w-full h-32 bg-gray-900 text-gray-100 p-3 rounded font-mono text-sm"
          placeholder="Enter PowerShell command..."
        />
        <button
         onClick={runCommand}
          disabled={loading}
          className="mt-3 px-6 py-2 bg-green-600 hover:bg-green-700 rounded text-white"
        >
          {loading ? "Running..." : "Execute"}
        </button>
      </div>
      {output && (
        <div className="bg-gray-900 rounded-lg p-4">
          <h3 className="text-lg font-semibold text-gray-300 mb-2">Output:</h3>
          <pre className="text-sm text-green-400 whitespace-pre-wrap font-mono">{output}</pre>
        </div>
      )}
    </div>
  );
}

// ==================== MAIN APP ====================
function App() {
  const [activeModule, setActiveModule] = useState("dashboard");

  const modules = [
    { id: "dashboard", name: "🏠 Dashboard", component: <DashboardModule /> },
    { id: "fixit", name: "🔧 Fix It", component: <FixItModule /> },
    { id: "processes", name: "📊 Processes", component: <ProcessModule /> },
    { id: "powershell", name: "💻 PowerShell", component: <PowerShellModule /> },
  ];

  const activeComponent = modules.find((m) => m.id === activeModule)?.component;

  return (
    <div className="flex h-screen bg-gray-900 text-gray-100">
      {/* Sidebar */}
      <div className="w-64 bg-gray-800 border-r border-gray-700 flex flex-col">
        <div className="p-6 border-b border-gray-700">
          <h1 className="text-3xl font-bold text-blue-400">DeskSOS</h1>
          <p className="text-sm text-gray-400 mt-1">Desktop Support Toolkit</p>
        </div>
        <nav className="flex-1 p-4 space-y-2">
          {modules.map((module) => (
            <button
              key={module.id}
              onClick={() => setActiveModule(module.id)}
              className={`w-full text-left px-4 py-3 rounded transition ${
                activeModule === module.id
                  ? "bg-blue-600 text-white font-semibold"
                  : "text-gray-300 hover:bg-gray-700"
              }`}
            >
              {module.name}
            </button>
          ))}
        </nav>
        <div className="p-4 border-t border-gray-700 text-xs text-gray-500">
          <p>Version 1.0.0</p>
          <p>© 2026 DeskSOS</p>
        </div>
      </div>

      {/* Main Content */}
      <div className="flex-1 overflow-auto">
        <div className="p-8">{activeComponent}</div>
      </div>
    </div>
  );
}

// ==================== HELPER COMPONENTS ====================
function InfoCard({ label, value }: { label: string; value?: string }) {
  return (
    <div className="bg-gray-700 p-3 rounded">
      <div className="text-sm text-gray-400">{label}</div>
      <div className="text-lg font-semibold text-white">{value || "N/A"}</div>
    </div>
  );
}

function StatusIndicator({ label, status }: { label: string; status?: boolean }) {
  return (
    <div className="flex items-center justify-between">
      <span className="text-gray-300">{label}</span>
      <span className={`w-3 h-3 rounded-full ${status ? "bg-green-500" : "bg-red-500"}`}></span>
    </div>
  );
}

function ActionButton({
  label,
  onClick,
  loading,
  danger = false,
  disabled = false,
}: {
  label: string;
  onClick: () => void;
  loading: boolean;
  danger?: boolean;
  disabled?: boolean;
}) {
  return (
    <button
      onClick={onClick}
      disabled={loading || disabled}
      className={`px-4 py-3 rounded font-semibold transition ${
        danger
          ? "bg-red-600 hover:bg-red-700 text-white"
          : "bg-blue-600 hover:bg-blue-700 text-white"
      } disabled:opacity-50 disabled:cursor-not-allowed`}
    >
      {loading ? "Working..." : label}
    </button>
  );
}: {
  label: string;
  onClick: () => void;
  loading: boolean;
  danger?: boolean;
  disabled?: boolean;
}) {
  return (
    <button
      onClick={onClick}
      disabled={loading}
      className={`px-4 py-3 rounded font-semibold transition ${
        danger
          ? "bg-red-600 hover:bg-red-700 text-white"
          : "bg-blue-600 hover:bg-blue-700 text-white"
      } disabled:opacity-50 disabled:cursor-not-allowed`" disabled={loading || disabled}`}
    >
      {loading ? "Working..." : label}
    </button>
  );
}


function StatusCard({ label, value, isGood }: { label: string; value: string; isGood: boolean }) {
  return (
    <div className={`p-3 rounded ${isGood ? "bg-green-900/30 border border-green-700" : "bg-red-900/30 border border-red-700"}`}>
      <div className="text-sm text-gray-400">{label}</div>
      <div className={`text-lg font-semibold ${isGood ? "text-green-400" : "text-red-400"}`}>{value}</div>
    </div>
  );
}

export default App;





