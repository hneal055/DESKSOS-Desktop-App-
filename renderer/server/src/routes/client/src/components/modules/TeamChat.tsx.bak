import React, { useState, useEffect, useRef, useCallback, useMemo } from "react";
import { Send, Users, MessageSquare, Bell, AtSign, AlertCircle, Loader } from "lucide-react";
import { api, Message as ApiMessage, Channel as ApiChannel, User } from "../../services/api";
import { formatDistance } from "date-fns";
import { toast } from "sonner";

interface Message {
  id: string;
  content: string;
  userId: string;
  userName: string;
  userAvatar?: string;
  timestamp: Date;
  mentions: string[];
  channel: string;
}

interface Channel {
  id: string;
  name: string;
  type: "public" | "private";
  unreadCount: number;
  lastMessage?: string;
}

const TeamChat = () => {
  const [channels, setChannels] = useState<Channel[]>([]);
  const [activeChannel, setActiveChannel] = useState<Channel | null>(null);
  const [messages, setMessages] = useState<Message[]>([]);
  const [newMessage, setNewMessage] = useState("");
  const [onlineUsers, setOnlineUsers] = useState<User[]>([]);
  const messagesEndRef = useRef<HTMLDivElement>(null);
  const [typingUsers, setTypingUsers] = useState<Map<string, number>>(new Map());
  const typingTimeoutRef = useRef<Map<string, NodeJS.Timeout>>(new Map());
  const [channelsLoading, setChannelsLoading] = useState(true);
  const [channelsError, setChannelsError] = useState<string | null>(null);
  const [messagesLoading, setMessagesLoading] = useState(false);
  const [sendingMessage, setSendingMessage] = useState(false);
  const currentUserRef = useRef<User | null>(null);

  // Initialize WebSocket connection once
  useEffect(() => {
    const initializeConnection = async () => {
      try {
        // Get current user
        const userResponse = await api.getCurrentUser();
        if (userResponse.error || !userResponse.data) {
          setChannelsError("Failed to load user profile");
          return;
        }

        const currentUser = userResponse.data;
        currentUserRef.current = currentUser;

        // Connect WebSocket
        await api.connectWebSocket(currentUser.id, currentUser.name);
        const socket = api.getSocket();

        if (socket) {
          setupSocketListeners(socket);
        } else {
          setChannelsError("Failed to establish real-time connection");
        }
      } catch (error) {
        setChannelsError("Failed to connect to chat service");
        console.error("Connection failed:", error);
      }
    };

    initializeConnection();

    return () => {
      api.disconnectWebSocket();
    };
  }, []);

  // Load channels on mount
  useEffect(() => {
    const loadChannels = async () => {
      setChannelsLoading(true);
      setChannelsError(null);
      try {
        const response = await api.getChannels();
        if (response.error || !response.data) {
          throw new Error(response.error || "Failed to load channels");
        }

        const formattedChannels: Channel[] = response.data.map((ch: ApiChannel) => ({
          id: ch.id,
          name: ch.name,
          type: ch.type,
          unreadCount: ch.unreadCount,
          lastMessage: ch.lastMessage,
        }));

        setChannels(formattedChannels);
        if (formattedChannels.length > 0 && !activeChannel) {
          setActiveChannel(formattedChannels[0]);
        }
      } catch (error) {
        const errorMsg = error instanceof Error ? error.message : "Failed to load channels";
        setChannelsError(errorMsg);
        toast.error(errorMsg);
      } finally {
        setChannelsLoading(false);
      }
    };

    loadChannels();
  }, []);

  // Load message history when channel changes
  useEffect(() => {
    if (!activeChannel) return;

    const loadMessages = async () => {
      setMessagesLoading(true);
      try {
        const response = await api.getChannelMessages(activeChannel.id);
        if (response.error || !response.data) {
          throw new Error(response.error || "Failed to load messages");
        }

        const formattedMessages: Message[] = response.data.map((msg: ApiMessage) => ({
          id: msg.id,
          content: msg.content,
          userId: msg.userId,
          userName: msg.userName,
          userAvatar: msg.userAvatar,
          timestamp: new Date(msg.timestamp),
          mentions: msg.mentions || [],
          channel: msg.channel,
        }));

        setMessages(formattedMessages);

        // Clear unread count
        setChannels((prev) =>
          prev.map((ch) =>
            ch.id === activeChannel.id ? { ...ch, unreadCount: 0 } : ch
          )
        );
      } catch (error) {
        console.error("Failed to load messages:", error);
        toast.error("Failed to load messages");
      } finally {
        setMessagesLoading(false);
      }
    };

    loadMessages();
  }, [activeChannel?.id]);

  const setupSocketListeners = useCallback(
    (socket: any) => {
      // New message received
      socket.on("message:new", (message: ApiMessage) => {
        const formattedMessage: Message = {
          id: message.id,
          content: message.content,
          userId: message.userId,
          userName: message.userName,
          userAvatar: message.userAvatar,
          timestamp: new Date(message.timestamp),
          mentions: message.mentions || [],
          channel: message.channel,
        };

        if (message.channel === activeChannel?.id) {
          setMessages((prev) => [...prev, formattedMessage]);
          scrollToBottom();
        } else {
          // Update unread count
          setChannels((prev) =>
            prev.map((ch) =>
              ch.id === message.channel
                ? { ...ch, unreadCount: ch.unreadCount + 1 }
                : ch
            )
          );
        }
      });

      // User typing indicator
      socket.on("user:typing", ({ userId, userName, channel }: any) => {
        if (channel === activeChannel?.id && userId !== currentUserRef.current?.id) {
          setTypingUsers((prev) => {
            const newMap = new Map(prev);
            newMap.set(userId, Date.now());
            return newMap;
          });

          // Clear existing timeout
          if (typingTimeoutRef.current.has(userId)) {
            clearTimeout(typingTimeoutRef.current.get(userId)!);
          }

          // Set new timeout
          const timeout = setTimeout(() => {
            setTypingUsers((prev) => {
              const newMap = new Map(prev);
              newMap.delete(userId);
              return newMap;
            });
            typingTimeoutRef.current.delete(userId);
          }, 3000);

          typingTimeoutRef.current.set(userId, timeout);
        }
      });

      // Presence update
      socket.on("presence:update", ({ onlineUsers: users }: any) => {
        setOnlineUsers(users || []);
      });
    },
    [activeChannel?.id]
  );

  const scrollToBottom = () => {
    messagesEndRef.current?.scrollIntoView({ behavior: "smooth" });
  };

  const sendMessage = useCallback(async () => {
    if (
      !newMessage.trim() ||
      !activeChannel ||
      !currentUserRef.current ||
      !api.isWebSocketConnected()
    ) {
      toast.error("Unable to send message. Check connection and try again.");
      return;
    }

    const mentions = newMessage.match(/@(\w+)/g)?.map((m) => m.substring(1)) || [];
    const messageId = `temp-${Date.now()}`;

    const message: Message = {
      id: messageId,
      content: newMessage,
      userId: currentUserRef.current.id,
      userName: currentUserRef.current.name,
      userAvatar: currentUserRef.current.avatar,
      channel: activeChannel.id,
      mentions,
      timestamp: new Date(),
    };

    // Optimistically add to UI
    setMessages((prev) => [...prev, message]);
    setNewMessage("");
    setSendingMessage(true);
    scrollToBottom();

    try {
      const socket = api.getSocketOrThrow();

      // Send via WebSocket
      socket.emit("message:send", message, (response: any) => {
        if (response?.error) {
          // Rollback failed message
          setMessages((prev) => prev.filter((m) => m.id !== messageId));
          toast.error(`Failed to send message: ${response.error}`);
        } else if (response?.id) {
          // Update message ID with server-generated ID
          setMessages((prev) =>
            prev.map((m) => (m.id === messageId ? { ...m, id: response.id } : m))
          );
        }
        setSendingMessage(false);
      });
    } catch (error) {
      setMessages((prev) => prev.filter((m) => m.id !== messageId));
      toast.error("Failed to send message");
      setSendingMessage(false);
    }
  }, [newMessage, activeChannel]);

  const handleTyping = useCallback(() => {
    if (!activeChannel || !api.isWebSocketConnected()) return;
    const socket = api.getSocket();
    if (socket) {
      socket.emit("user:typing", {
        userId: currentUserRef.current?.id,
        channel: activeChannel.id,
      });
    }
  }, [activeChannel]);

  const typingUsersList = useMemo(() => {
    return Array.from(typingUsers.keys());
  }, [typingUsers]);

  // Error state
  if (channelsError && channels.length === 0) {
    return (
      <div className="flex h-full bg-white items-center justify-center">
        <div className="text-center">
          <AlertCircle className="w-16 h-16 text-error mx-auto mb-4" />
          <h3 className="text-lg font-medium text-slate-900 mb-2">
            Connection Error
          </h3>
          <p className="text-slate-600">{channelsError}</p>
        </div>
      </div>
    );
  }

  return (
    <div className="flex h-full bg-white">
      {/* Channel List */}
      <div className="w-64 border-r border-slate-200 bg-slate-50 flex flex-col">
        <div className="p-4 border-b border-slate-200">
          <h2 className="font-semibold">Channels</h2>
        </div>
        <div className="p-2 flex-1 overflow-y-auto">
          {channelsLoading ? (
            <div className="flex items-center justify-center py-8">
              <Loader className="w-4 h-4 animate-spin text-slate-400" />
            </div>
          ) : channels.length === 0 ? (
            <p className="text-xs text-slate-500 text-center py-4">
              No channels available
            </p>
          ) : (
            channels.map((channel) => (
              <button
                key={channel.id}
                onClick={() => setActiveChannel(channel)}
                className={`w-full text-left p-3 rounded-lg mb-1 transition-colors ${
                  activeChannel?.id === channel.id
                    ? "bg-primary-50 text-primary-700"
                    : "hover:bg-slate-200"
                }`}
              >
                <div className="flex items-center justify-between">
                  <div className="flex items-center min-w-0">
                    <Users className="w-4 h-4 mr-2 flex-shrink-0" />
                    <span className="text-sm font-medium truncate">
                      #{channel.name}
                    </span>
                  </div>
                  {channel.unreadCount > 0 && (
                    <span className="bg-primary-600 text-white text-xs px-2 py-0.5 rounded-full ml-2 flex-shrink-0">
                      {channel.unreadCount}
                    </span>
                  )}
                </div>
              </button>
            ))
          )}
        </div>

        {/* Online Users */}
        <div className="border-t border-slate-200 p-4 bg-slate-50">
          <div className="flex items-center justify-between mb-2">
            <span className="text-xs font-medium text-slate-500">
              ONLINE — {onlineUsers.length}
            </span>
          </div>
          <div className="space-y-2 max-h-32 overflow-y-auto">
            {onlineUsers.length === 0 ? (
              <p className="text-xs text-slate-500">No one online</p>
            ) : (
              onlineUsers.map((user) => (
                <div key={user.id} className="flex items-center text-sm">
                  <div className="w-2 h-2 bg-success rounded-full mr-2" />
                  <span className="truncate">{user.name}</span>
                </div>
              ))
            )}
          </div>
        </div>
      </div>

      {/* Chat Area */}
      <div className="flex-1 flex flex-col">
        {activeChannel ? (
          <>
            {/* Channel Header */}
            <div className="p-4 border-b border-slate-200 flex items-center justify-between">
              <div>
                <h2 className="font-semibold">#{activeChannel.name}</h2>
                <p className="text-xs text-slate-500">Public channel</p>
              </div>
              <button className="p-2 hover:bg-slate-100 rounded-lg">
                <Bell className="w-4 h-4 text-slate-600" />
              </button>
            </div>

            {/* Messages */}
            <div className="flex-1 overflow-y-auto p-4 space-y-4">
              {messagesLoading ? (
                <div className="flex items-center justify-center h-full">
                  <Loader className="w-6 h-6 animate-spin text-primary-600" />
                </div>
              ) : messages.length === 0 ? (
                <div className="flex items-center justify-center h-full text-slate-500">
                  <p>No messages yet. Start the conversation!</p>
                </div>
              ) : (
                messages.map((message) => (
                  <div key={message.id} className="flex space-x-3">
                    <div className="w-8 h-8 bg-primary-100 rounded-full flex items-center justify-center flex-shrink-0">
                      {message.userAvatar ? (
                        <img
                          src={message.userAvatar}
                          alt={message.userName}
                          className="w-8 h-8 rounded-full"
                        />
                      ) : (
                        <span className="text-sm font-medium text-primary-600">
                          {message.userName[0] || "?"}
                        </span>
                      )}
                    </div>
                    <div className="flex-1">
                      <div className="flex items-center space-x-2">
                        <span className="font-medium text-sm">{message.userName}</span>
                        <span className="text-xs text-slate-500">
                          {formatDistance(message.timestamp, new Date(), {
                            addSuffix: true,
                          })}
                        </span>
                        {message.id.startsWith("temp-") && (
                          <span className="text-xs text-slate-400">Sending...</span>
                        )}
                      </div>
                      <p className="text-sm text-slate-700 mt-1">{message.content}</p>

                      {/* Mentions */}
                      {message.mentions.length > 0 && (
                        <div className="flex items-center space-x-1 mt-2">
                          <AtSign className="w-3 h-3 text-primary-600" />
                          <span className="text-xs text-primary-600">
                            Mentioned: {message.mentions.join(", ")}
                          </span>
                        </div>
                      )}
                    </div>
                  </div>
                ))
              )}

              {/* Typing indicator */}
              {typingUsersList.length > 0 && (
                <div className="flex items-center space-x-2 text-sm text-slate-500">
                  <div className="flex space-x-1">
                    <div className="w-2 h-2 bg-slate-400 rounded-full animate-bounce" />
                    <div
                      className="w-2 h-2 bg-slate-400 rounded-full animate-bounce"
                      style={{ animationDelay: "0.2s" }}
                    />
                    <div
                      className="w-2 h-2 bg-slate-400 rounded-full animate-bounce"
                      style={{ animationDelay: "0.4s" }}
                    />
                  </div>
                  <span>{typingUsersList.join(", ")} typing...</span>
                </div>
              )}

              <div ref={messagesEndRef} />
            </div>

            {/* Message Input */}
            <div className="p-4 border-t border-slate-200">
              <div className="flex space-x-2">
                <input
                  type="text"
                  value={newMessage}
                  onChange={(e) => setNewMessage(e.target.value)}
                  onKeyPress={(e) => {
                    if (e.key === "Enter" && !e.shiftKey) {
                      e.preventDefault();
                      sendMessage();
                    }
                  }}
                  onKeyDown={handleTyping}
                  placeholder={`Message #${activeChannel.name}`}
                  disabled={sendingMessage}
                  className="flex-1 px-4 py-2 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500 disabled:bg-slate-50 disabled:text-slate-400"
                />
                <button
                  onClick={sendMessage}
                  disabled={sendingMessage || !newMessage.trim()}
                  className="btn-primary px-4 disabled:opacity-50 disabled:cursor-not-allowed"
                >
                  <Send className="w-4 h-4" />
                </button>
              </div>
            </div>
          </>
        ) : (
          <div className="h-full flex items-center justify-center">
            <div className="text-center">
              <MessageSquare className="w-16 h-16 text-slate-300 mx-auto mb-4" />
              <h3 className="text-lg font-medium text-slate-900 mb-2">
                Select a Channel
              </h3>
              <p className="text-slate-600">
                Choose a channel to start collaborating with your team
              </p>
            </div>
          </div>
        )}
      </div>
    </div>
  );
};

export default TeamChat;
